#!/bin/sh

set -eu

# shellcheck source=ci/lib.sh
. "$(dirname -- "$0")/lib.sh"

require_tool curl
require_tool npm
require_tool sha256sum
require_tool tar

mkdir -p "$TOOLS_DIR"

machine=$(uname -m)
case "$machine" in
x86_64)
	actionlint_arch=amd64
	actionlint_sha=8aca8db96f1b94770f1b0d72b6dddcb1ebb8123cb3712530b08cc387b349a3d8
	gitleaks_arch=x64
	gitleaks_sha=551f6fc83ea457d62a0d98237cbad105af8d557003051f41f3e7ca7b3f2470eb
	;;
aarch64 | arm64)
	actionlint_arch=arm64
	actionlint_sha=325e971b6ba9bfa504672e29be93c24981eeb1c07576d730e9f7c8805afff0c6
	gitleaks_arch=arm64
	gitleaks_sha=e4a487ee7ccd7d3a7f7ec08657610aa3606637dab924210b3aee62570fb4b080
	;;
*)
	die "unsupported bootstrap architecture: $machine"
	;;
esac

install_archive() {
	tool=$1
	url=$2
	expected_sha=$3

	if [ -x "$TOOLS_DIR/$tool" ]; then
		return
	fi

	temporary_dir=$(mktemp -d "${TMPDIR:-/tmp}/franken-ci-tool.XXXXXX")
	archive="$temporary_dir/archive.tar.gz"
	curl --fail --location --silent --show-error "$url" --output "$archive"
	printf '%s  %s\n' "$expected_sha" "$archive" | sha256sum --check -
	tar -xzf "$archive" -C "$temporary_dir"
	install -m 0755 "$temporary_dir/$tool" "$TOOLS_DIR/$tool"
	rm -rf "$temporary_dir"
}

install_archive \
	actionlint \
	"https://github.com/rhysd/actionlint/releases/download/v1.7.12/actionlint_1.7.12_linux_${actionlint_arch}.tar.gz" \
	"$actionlint_sha"

install_archive \
	gitleaks \
	"https://github.com/gitleaks/gitleaks/releases/download/v8.30.1/gitleaks_8.30.1_linux_${gitleaks_arch}.tar.gz" \
	"$gitleaks_sha"

npm ci --ignore-scripts
