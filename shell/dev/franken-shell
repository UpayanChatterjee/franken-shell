#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SHELL_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CONFIG_HELPER_DIR="$SHELL_DIR/helpers/franken-config-helper"
CONFIG_FIXTURE_DIR="$CONFIG_HELPER_DIR/tests/fixtures"
CONFIG_DEMO_DIR=${TMPDIR:-/tmp}/franken-shell-config-demo-$(id -u)
if [ -x /usr/lib/qt6/bin/qmllint ]; then
    QMLLINT=${QMLLINT:-/usr/lib/qt6/bin/qmllint}
else
    QMLLINT=${QMLLINT:-qmllint}
fi

is_running() {
    qs ipc --path "$SHELL_DIR" show >/dev/null 2>&1
}

diagnostics_ready() {
    summary=$(qs ipc --path "$SHELL_DIR" call diagnostics summary 2>/dev/null) || return 1
    case "$summary" in
        \{*) return 0 ;;
        *) return 1 ;;
    esac
}

wait_for_diagnostics() {
    attempts=0
    while [ "$attempts" -lt 50 ]; do
        if diagnostics_ready; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    return 1
}

wait_for_stop() {
    attempts=0
    while [ "$attempts" -lt 50 ]; do
        if ! is_running; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    return 1
}

start_instance() {
    mode=$1
    fixture_path=${2:-}
    if is_running; then
        printf 'Franken Shell is already running from %s\n' "$SHELL_DIR"
        return 0
    fi

    if [ -n "$fixture_path" ]; then
        FRANKEN_SHELL_MODE=$mode \
        FRANKEN_CONFIG_FIXTURE_PATH=$fixture_path \
            qs --no-duplicate --daemonize --path "$SHELL_DIR" --log-times
    else
        FRANKEN_CONFIG_FIXTURE_PATH= \
        FRANKEN_SHELL_MODE=$mode \
            qs --no-duplicate --daemonize --path "$SHELL_DIR" --log-times
    fi
    if ! wait_for_diagnostics; then
        printf 'Franken Shell did not become ready. Inspect logs with: %s logs\n' "$0" >&2
        return 1
    fi
    printf 'Franken Shell started in %s mode from %s\n' "$mode" "$SHELL_DIR"
}

stop_instance() {
    if ! is_running; then
        rm -rf "$CONFIG_DEMO_DIR"
        printf 'Franken Shell is not running from %s\n' "$SHELL_DIR"
        return 0
    fi
    qs kill --path "$SHELL_DIR"
    if ! wait_for_stop; then
        printf 'Franken Shell did not stop cleanly.\n' >&2
        return 1
    fi
    rm -rf "$CONFIG_DEMO_DIR"
}

verify_baseline() {
    actual=$(qs --version)
    printf '%s\n' "$actual"
    case "$actual" in
        *"Quickshell 0.3.0"*"4df562dfb2475a9057f0f33a8db75808efad8670"*) ;;
        *)
            printf 'Expected Quickshell 0.3.0 at commit 4df562dfb2475a9057f0f33a8db75808efad8670\n' >&2
            return 1
            ;;
    esac

    if command -v pacman >/dev/null 2>&1; then
        pacman -Q quickshell-git qt6-base hyprland
    fi
}

show_diagnostics() {
    if ! is_running; then
        printf 'Franken Shell is not running from %s\n' "$SHELL_DIR" >&2
        return 1
    fi
    qs ipc --path "$SHELL_DIR" call diagnostics summary
    printf 'runtimeQuickshell='
    qs --version
    if command -v hyprctl >/dev/null 2>&1; then
        printf 'runtimeHyprland='
        hyprctl version | sed -n '1p'
    fi
}

check_qml() {
    find "$SHELL_DIR" -name '*.qml' -print0 \
        | xargs -0 "$QMLLINT" -I "$SHELL_DIR" -I /usr/lib/qt6/qml
}

build_config_helper() {
    cargo build --locked --manifest-path "$CONFIG_HELPER_DIR/Cargo.toml"
}

test_config_helper() {
    cargo test --locked --manifest-path "$CONFIG_HELPER_DIR/Cargo.toml"
}

test_config_helper_client() {
    runtime_dir=${TMPDIR:-/tmp}/franken-shell-config-helper-client-$(id -u)
    mkdir -p "$runtime_dir"
    chmod 700 "$runtime_dir"
    build_config_helper
    QT_QPA_PLATFORM=offscreen \
    XDG_RUNTIME_DIR="$runtime_dir" \
    FRANKEN_CONFIG_HELPER_TEST_FAKE="$SHELL_DIR/tests/config_helper/fake-config-helper" \
        qs --no-duplicate --path "$SHELL_DIR/config-helper-client-tests.qml" --log-times
}

check_config_service() {
    "$QMLLINT" -I "$SHELL_DIR" -I /usr/lib/qt6/qml \
        "$SHELL_DIR/core/ConfigDefaults.js" \
        "$SHELL_DIR/core/ConfigPathResolver.js" \
        "$SHELL_DIR/core/ConfigSnapshotBuilder.js" \
        "$SHELL_DIR/core/ConfigValueList.qml" \
        "$SHELL_DIR/core/ConfigValueMap.qml" \
        "$SHELL_DIR/core/ConfigSnapshot.qml" \
        "$SHELL_DIR/core/ConfigService.qml" \
        "$SHELL_DIR/tests/config_service/FakeConfigHelperClient.qml" \
        "$SHELL_DIR/tests/config_service/ConfigServiceTests.qml" \
        "$SHELL_DIR/tests/config_service/ConfigServiceIntegrationTests.qml"
}

check_monitor_registry() {
    "$QMLLINT" -I "$SHELL_DIR" -I /usr/lib/qt6/qml \
        "$SHELL_DIR/core/MonitorNormalization.js" \
        "$SHELL_DIR/core/MonitorRecord.qml" \
        "$SHELL_DIR/core/HyprlandMonitorAdapter.qml" \
        "$SHELL_DIR/core/MonitorRegistry.qml" \
        "$SHELL_DIR/tests/monitor_registry/FakeMonitorBackend.qml" \
        "$SHELL_DIR/tests/monitor_registry/MonitorRegistryTests.qml"
}

test_monitor_registry() {
    runtime_dir=$(mktemp -d "${TMPDIR:-/tmp}/franken-shell-monitor-runtime.XXXXXX")
    chmod 700 "$runtime_dir"

    result=0
    QT_QPA_PLATFORM=offscreen \
    XDG_RUNTIME_DIR="$runtime_dir" \
    FRANKEN_SHELL_MODE=monitor-registry-test \
        qs --no-duplicate --path "$SHELL_DIR/monitor-registry-tests.qml" --log-times || result=$?
    rm -rf "$runtime_dir"
    return "$result"
}

show_monitor_diagnostics() {
    if ! is_running; then
        printf 'Franken Shell is not running from %s\n' "$SHELL_DIR" >&2
        return 1
    fi
    qs ipc --path "$SHELL_DIR" call diagnostics monitorStatus
}

observe_monitors() {
    if ! command -v hyprctl >/dev/null 2>&1; then
        printf 'hyprctl is unavailable.\n' >&2
        return 1
    fi
    hyprctl monitors -j | jq '[.[] | {
        id,
        name,
        x,
        y,
        width,
        height,
        scale,
        transform,
        focused,
        activeWorkspace: .activeWorkspace.id
    }]'
}

run_config_service_test() {
    entrypoint=$1
    runtime_dir=$(mktemp -d "${TMPDIR:-/tmp}/franken-shell-config-runtime.XXXXXX")
    fixture_dir=$(mktemp -d "${TMPDIR:-/tmp}/franken-shell-config-fixture.XXXXXX")
    chmod 700 "$runtime_dir"

    result=0
    QT_QPA_PLATFORM=offscreen \
    XDG_RUNTIME_DIR="$runtime_dir" \
    FRANKEN_SHELL_MODE=config-service-test \
    FRANKEN_CONFIG_FIXTURE_PATH="$fixture_dir/config.toml" \
    FRANKEN_CONFIG_FIXTURE_DIRECTORY="$CONFIG_FIXTURE_DIR" \
        qs --no-duplicate --path "$entrypoint" --log-times || result=$?
    rm -rf "$runtime_dir" "$fixture_dir"
    return "$result"
}

test_config_service() {
    build_config_helper
    run_config_service_test "$SHELL_DIR/config-service-tests.qml"
    run_config_service_test "$SHELL_DIR/config-service-integration-tests.qml"
}

start_config_demo() {
    fixture=${1:-"$CONFIG_FIXTURE_DIR/missing_optional.toml"}
    if [ ! -f "$fixture" ]; then
        printf 'Config demo fixture does not exist: %s\n' "$fixture" >&2
        return 2
    fi
    fixture_root=$(CDPATH= cd -- "$CONFIG_FIXTURE_DIR" && pwd -P)
    fixture_dir=$(CDPATH= cd -- "$(dirname -- "$fixture")" && pwd -P)
    fixture=$fixture_dir/$(basename -- "$fixture")
    case "$fixture" in
        "$fixture_root"/*) ;;
        *)
            printf 'Config demo accepts only repository helper fixtures under %s\n' \
                "$fixture_root" >&2
            return 2
            ;;
    esac

    mkdir -p "$CONFIG_DEMO_DIR"
    cp "$fixture" "$CONFIG_DEMO_DIR/config.toml"
    if ! start_instance config-demo "$CONFIG_DEMO_DIR/config.toml"; then
        rm -rf "$CONFIG_DEMO_DIR"
        return 1
    fi
    printf 'Temporary demo configuration: %s\n' "$CONFIG_DEMO_DIR/config.toml"
}

run_config_helper() {
    cargo run --quiet --locked \
        --manifest-path "$CONFIG_HELPER_DIR/Cargo.toml" \
        --bin franken-config-helper
}

validate_config_fixture() {
    fixture=${1:-}
    if [ -z "$fixture" ] || [ ! -f "$fixture" ]; then
        printf 'Usage: %s config-helper-validate-fixture TOML_FILE\n' "$0" >&2
        return 2
    fi
    if ! command -v jq >/dev/null 2>&1; then
        printf 'config-helper-validate-fixture requires jq for development request construction.\n' >&2
        return 1
    fi

    jq -Rs \
        --arg source "$fixture" \
        '{
            protocolVersion: 1,
            requestGeneration: 1,
            operation: "validateAndNormalize",
            sourceIdentifier: $source,
            tomlSource: .
        }' \
        "$fixture" | run_config_helper
}

usage() {
    printf '%s\n' \
        "Usage: $0 COMMAND" \
        "" \
        "Commands:" \
        "  start             Start non-owning development mode" \
        "  mock              Start non-owning mock mode" \
        "  stop              Stop only this repository-path instance" \
        "  restart           Full process restart in development mode" \
        "  reload            Request an in-process soft reload" \
        "  config-reload     Request ConfigService to reread its current path" \
        "  logs [LINES]      Show recent Quickshell logs" \
        "  diagnostics       Show bootstrap and runtime diagnostics" \
        "  config-status     Show sanitized active configuration status" \
        "  verify-baseline   Verify the tested local runtime baseline" \
        "  check             Check QML syntax and imports" \
        "  config-helper-build" \
        "                    Build the Rust configuration helper" \
        "  config-helper-test" \
        "                    Run configuration helper unit and fixture tests" \
        "  config-helper-client-test" \
        "                    Exercise the QML helper client against controlled fixtures" \
        "  config-service-check" \
        "                    Statically check ConfigService and its typed snapshot files" \
        "  config-service-test" \
        "                    Run fake-client lifecycle and real-helper fixture tests" \
        "  monitor-registry-check" \
        "                    Statically check the monitor registry service boundary" \
        "  monitor-registry-test" \
        "                    Run deterministic monitor normalization and lifecycle fixtures" \
        "  monitor-diagnostics" \
        "                    Show sanitized normalized monitor diagnostics" \
        "  monitor-observe" \
        "                    Read the current Hyprland monitor state without dispatching commands" \
        "  config-demo [FIXTURE_TOML]" \
        "                    Start non-owning mode with a copied temporary configuration" \
        "  config-helper-validate-fixture TOML_FILE" \
        "                    Validate one TOML fixture through protocol v1" \
        "  config-helper-pipe" \
        "                    Pipe one JSON protocol request to the helper"
}

command=${1:-help}
case "$command" in
    start)
        start_instance development
        ;;
    mock)
        start_instance mock
        ;;
    stop)
        stop_instance
        ;;
    restart)
        stop_instance
        start_instance development
        ;;
    reload)
        qs ipc --path "$SHELL_DIR" call diagnostics reload
        if ! wait_for_diagnostics; then
            printf 'Franken Shell did not become ready after reload.\n' >&2
            exit 1
        fi
        ;;
    config-reload)
        qs ipc --path "$SHELL_DIR" call diagnostics reloadConfig
        ;;
    logs)
        qs log --path "$SHELL_DIR" --tail "${2:-100}"
        ;;
    diagnostics)
        show_diagnostics
        ;;
    config-status)
        qs ipc --path "$SHELL_DIR" call diagnostics configStatus
        ;;
    verify-baseline)
        verify_baseline
        ;;
    check)
        check_qml
        ;;
    config-helper-build)
        build_config_helper
        ;;
    config-helper-test)
        test_config_helper
        ;;
    config-helper-client-test)
        test_config_helper_client
        ;;
    config-service-check)
        check_config_service
        ;;
    config-service-test)
        test_config_service
        ;;
    monitor-registry-check)
        check_monitor_registry
        ;;
    monitor-registry-test)
        test_monitor_registry
        ;;
    monitor-diagnostics)
        show_monitor_diagnostics
        ;;
    monitor-observe)
        observe_monitors
        ;;
    config-demo)
        start_config_demo "${2:-}"
        ;;
    config-helper-validate-fixture)
        validate_config_fixture "${2:-}"
        ;;
    config-helper-pipe)
        run_config_helper
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac
